#Choose the train type you want to book,the type is "departureStation_firstfacility", 
#the options are mipo_skycapsule = 1, mipo_beachtrain = 2, Cheongsapo_skycapsule = 3, Cheongsapo_beachtrain = 4 ,please enter the number of the train type you want to book
TICKET_TYPE=1

#START BOT TIME
USE_START_TIME=True
START_TIME=2026-12-31 00:00:00

# ORDER TIME
YEAR_MONTH=2026-01
DATE=01

# CHOOSE TIME NUMBER
SKY_CAPSULE_TIME_NUMBER=1
BEACH_TRAIN_TIME_NUMBER=2

# PERSON NUMBERS,if you want to book for 3 people, set it to [3], if you want more, set it to [3,4,2,...],the max number is 4
PERSON_NUMBERS=[2]

# ORDER INFO
ORDER_NAME=Test
ORDER_PHONE=
ORDER_EMAIL=test@example.com
ORDER_PASSWORD=1234
ORDER_COUNTRY=

